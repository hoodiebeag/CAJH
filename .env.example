# ─── Required ────────────────────────────────────────────────────────────────
# Discord bot token (Discord Developer Portal → your app → Bot → Reset Token)
DISCORD_BOT_TOKEN=

# Anthropic API key for chart analysis (console.anthropic.com)
ANTHROPIC_API_KEY=

# Kraken Spot API credentials (kraken.com → Settings → API).
# The key needs "Query Funds" + "Create & Modify Orders" permissions.
# Leave these blank to run analysis-only with no live trading.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ─── Optional ────────────────────────────────────────────────────────────────
# Discord channel ID where scans/alerts post. Can also be set at runtime with
# !setchannel (which persists to config.json).
SCAN_CHANNEL_ID=

# Minimum conviction (1–10) required to surface a setup. Default: 6
CONVICTION_THRESHOLD=6

# Comma-separated default watchlist, e.g. BTC,ETH,SOL. Falls back to the built-in
# 20-pair list if unset.
WATCHLIST=

# Your Discord user ID — cajh pings this on every new trade. Defaults to beag's ID.
BEAG_USER_ID=

# Persistent data directory. On Railway, attach a volume and set this to its mount
# path (e.g. /data) so config.json and positions.json survive redeploys. Leave blank
# for local dev (uses the app folder).
DATA_DIR=
